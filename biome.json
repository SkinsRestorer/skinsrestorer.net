{
  "$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!.next",
      "!dist",
      "!build",
      "!coverage",
      "!out",
      "!.source",
      "!postcss.config.mjs"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "includes": [
      "**",
      "!src/components/ui/**",
      "!src/components/data-table/**"
    ],
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "noUnresolvedImports": "off",
        "useImportExtensions": "off"
      },
      "style": {
        "useComponentExportOnlyModules": "off"
      }
    },
    "domains": {
      "next": "all",
      "react": "all",
      "project": "all"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["public/**/*.svg"],
      "linter": {
        "rules": {
          "a11y": {
            "noSvgWithoutTitle": "off"
          }
        }
      }
    }
  ]
}
